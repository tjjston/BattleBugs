SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///database/bug_arena.db
UPLOAD_FOLDER=/tmp/battlebugs-uploads
LLM_DEFAULT_PROVIDER=ollama
OLLAMA_API_URL=http://192.168.0.99:11434
# DeepSeek (text-only; OpenAI-compatible). Leave blank to disable.
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com
LLM_MODEL_VISION_ANALYSIS=GEMMA4_E4B
LLM_MODEL_STAT_GENERATION=QWEN36_35B
LLM_MODEL_BATTLE_NARRATIVE=QWEN36_35B
LLM_MODEL_SPECIES_IDENTIFICATION=QWEN36_35B
LLM_MODEL_QUICK_TASKS=QWEN36_35B
HF_BUG_CLASSIFIER_ENABLED=true
HF_BUG_CLASSIFIER_REQUIRED=false
HF_BUG_CLASSIFIER_MODEL=ph0masta/bug_classifier
HF_BUG_CLASSIFIER_MIN_CONFIDENCE=0.80
HF_BUG_CLASSIFIER_TOP_K=5
ENABLE_BACKGROUND_JOBS=true
JOB_POLL_INTERVAL_SECONDS=15
ENABLE_DB_EXPLORER=false
DB_EXPLORER_ALLOW_WRITES=false
